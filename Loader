local scripts = {
	-- Murder Mystery 2
	{
		ID = {{142823291, "Place"}},
		Callback = function()
			task.spawn(loadstring(game:HttpGet("https://raw.githubusercontent.com/qwirkzer/Qwirkz-Hub/refs/heads/main/mm2.lua")))
		end,
	}
}

local function findValidGame()
	for _, place in pairs(scripts) do
		local gameIds = place.ID
		
		if gameIds == "Universal" then
			return place
		elseif typeof(gameIds) == "table" then
			for _, id in pairs(gameIds) do
				if (id[2] == "Place" and id[1] == game.PlaceId) or (id[2] == "Game" and id[1] == game.GameId) then return place end
			end
		end
	end
	warn("qwirkz Hub > No script for this game")
end

local valid = findValidGame()
if valid then
	valid.Callback()
end
